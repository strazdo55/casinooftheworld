{
  "name": "casinooftheworld",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx --yes serve . -l 8080 --config serve.json",
    "build": "node scripts/build-all.mjs",
    "build:operators": "node scripts/build-operators.mjs",
    "build:home": "node scripts/generate-home.mjs",
    "build:reviews": "node scripts/build-reviews.mjs",
    "build:pages": "node scripts/generate-pages.mjs",
    "build:blog": "node scripts/build-blog.mjs",
    "build:blog:batch": "node scripts/add-blog-batch.mjs && node scripts/build-blog.mjs",
    "build:sitemap": "node scripts/generate-sitemap.mjs",
    "sync:schemas": "node scripts/sync-schemas.mjs",
    "sync:routes": "node scripts/write-serve-config.mjs",
    "migrate:clean-urls": "node scripts/migrate-clean-urls.mjs",
    "fix:redirects": "node scripts/fix-redirect-stubs.mjs",
    "fix:blog-links": "node scripts/fix-blog-links.mjs",
    "enrich": "node scripts/enrich-site.mjs",
    "gsc:verify-file": "node scripts/write-gsc-verification.mjs",
    "inject:cookie-banner": "node scripts/inject-cookie-banner.mjs",
    "inject:promo": "node scripts/inject-promo.mjs",
    "sync:headers": "node scripts/sync-headers.mjs",
    "patch:review-faqs": "node scripts/patch-review-faqs.mjs",
    "rebuild:intl": "node scripts/update-international-blog.mjs && node scripts/generate-blog-enrichment.mjs && npm run build:home && npm run build:pages && npm run build:reviews && npm run build:blog && npm run build:images:blog && npm run inject:cookie-banner && npm run build:sitemap",
    "patch:logo": "node scripts/patch-logo.mjs",
    "build:brand": "node scripts/write-brand-assets.mjs && npm run patch:logo",
    "build:images": "node scripts/generate-images.mjs",
    "build:images:blog": "node scripts/generate-images.mjs --blog-only --force",
    "optimize:images": "node scripts/optimize-images.mjs",
    "minify:css": "node scripts/minify-css.mjs",
    "patch:perf": "node scripts/patch-perf.mjs",
    "patch:site-shell": "node scripts/patch-site-shell.mjs",
    "perf": "npm run optimize:images && npm run minify:css && npm run patch:perf"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "sharp": "^0.34.5"
  }
}
